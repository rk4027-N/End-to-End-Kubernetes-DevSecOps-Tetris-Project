pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_REGION = "us-east-1"
        GIT_REPO_NAME = "End-to-End-Kubernetes-DevSecOps-Tetris-Project"
        GIT_USER_NAME = "rk4027-N"
    }

    stages {

        stage('Clean Workspace') {
            steps { cleanWs() }
        }

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                url: 'https://github.com/rk4027-N/End-to-End-Kubernetes-DevSecOps-Tetris-Project.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Tetris-V1') {
                    withSonarQubeEnv('sonar-scanner') {
                        sh """
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dsonar.projectName=Tetris \
                        -Dsonar.projectKey=Tetris
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: true
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('Tetris-V1') {
                    sh 'npm install'
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir('Tetris-V1') {
                    dependencyCheck additionalArguments: '--scan ./',
                    odcInstallation: 'DP-Check'
                }
            }
        }

        stage('Trivy Filesystem Scan') {
            steps {
                dir('Tetris-V1') {
                    sh 'trivy fs .'
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {

                    def awsAccountId = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()

                    def ecrRepo = "${awsAccountId}.dkr.ecr.${AWS_REGION}.amazonaws.com/tetrisv1"

                    dir('Tetris-V1') {
                        sh """
                            docker build -t ${ecrRepo}:${BUILD_NUMBER} .
                        """
                    }
                }
            }
        }

        stage('Docker Push to ECR') {
            steps {
                script {

                    def awsAccountId = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()

                    def ecrRepo = "${awsAccountId}.dkr.ecr.${AWS_REGION}.amazonaws.com/tetrisv1"

                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS --password-stdin ${awsAccountId}.dkr.ecr.${AWS_REGION}.amazonaws.com

                        docker push ${ecrRepo}:${BUILD_NUMBER}
                    """
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                script {
                    def awsAccountId = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()

                    def ecrRepo = "${awsAccountId}.dkr.ecr.${AWS_REGION}.amazonaws.com/tetrisv1"

                    sh "trivy image ${ecrRepo}:${BUILD_NUMBER}"
                }
            }
        }

        stage('Update Kubernetes Manifest (GitOps)') {
            steps {
                dir('Manifest-file') {
                    withCredentials([string(credentialsId: 'Github', variable: 'GITHUB_TOKEN')]) {
                        script {

                            def awsAccountId = sh(
                                script: "aws sts get-caller-identity --query Account --output text",
                                returnStdout: true
                            ).trim()

                            def ecrRepo = "${awsAccountId}.dkr.ecr.${AWS_REGION}.amazonaws.com/tetrisv1"

                            sh """
                                git config user.email "gudalarajkumar@gmail.com"
                                git config user.name "rknani"

                                sed -i "s|image:.*|image: ${ecrRepo}:${BUILD_NUMBER}|g" deployment-service.yml

                                git add deployment-service.yml
                                git commit -m "Update image to ${BUILD_NUMBER}"
                                git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                            """
                        }
                    }
                }
            }
        }
    }
}
